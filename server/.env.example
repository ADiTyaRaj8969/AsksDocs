# Copy this file to .env and fill in your values

# Required: Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Authentication — choose ONE of the two options below:

# Option A — Firebase (recommended, supports auto token refresh)
# Get from Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=your_firebase_project_id

# Option B — Raw Google OAuth (simpler, tokens expire after 1 h)
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Optional: Port for the Express server (default: 5000)
PORT=5000

# Optional: Comma-separated allowed CORS origins for dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
